<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="noia.Views.SettingsView">
	<StackPanel Margin="20" Spacing="15">
		<TextBlock Text="Settings" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>

		<!-- Option: Start at Last Position -->
		<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
			<TextBlock Text="Start at last position:" VerticalAlignment="Center" Width="200"/>
			<ToggleSwitch x:Name="StartAtLastPositionToggle" Width="100"/>
		</StackPanel>

		<!-- Option: Always on Top -->
		<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
			<TextBlock Text="Always on top:" VerticalAlignment="Center" Width="200"/>
			<ToggleSwitch x:Name="AlwaysOnTopToggle" Width="100"/>
		</StackPanel>
	</StackPanel>
</UserControl>
