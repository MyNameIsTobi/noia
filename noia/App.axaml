<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             x:Class="noia.App">
	<Application.Styles>
		<StyleInclude Source="avares://noia/Icons.axaml" />
		<FluentTheme>
			<FluentTheme.Palettes>
				<!-- Palette for Light theme variant -->
				<ColorPaletteResources x:Key="Light" Accent="Green" RegionColor="White" ErrorText="Red" />
				<!-- Palette for Dark theme variant -->
				<ColorPaletteResources x:Key="Dark" Accent="DarkGreen" RegionColor="Black" ErrorText="Yellow" />
			</FluentTheme.Palettes>
		</FluentTheme>
	</Application.Styles>
	<Application.Resources>
			<LinearGradientBrush x:Key="HPGradientBrush" StartPoint="0,0" EndPoint="1,0">
				<GradientStop Color="Red" Offset="0"/>
				<GradientStop Color="Yellow" Offset="1"/>
			</LinearGradientBrush>
			<LinearGradientBrush x:Key="ManaGradientBrush" StartPoint="0,0" EndPoint="1,0">
				<GradientStop Color="Blue" Offset="0"/>
				<GradientStop Color="LightBlue" Offset="1"/>
			</LinearGradientBrush>
	</Application.Resources>
</Application>
